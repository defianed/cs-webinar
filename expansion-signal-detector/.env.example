# Required to run: ANTHROPIC_API_KEY (or OPENAI_API_KEY), SLACK_BOT_TOKEN

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Slack notifications
SLACK_BOT_TOKEN=

# Test data (defaults are provided in test.py — override here to customise)
# ACCOUNT_NAME=
# TRANSCRIPT_TEXT=
# POST_CALL_NOTES=
