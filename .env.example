# =============================================================
# cs-webinar — single .env file for all workflows
# Copy this file to .env and fill in your values
# Place .env in the repo root — all workflows load from here
# =============================================================

# --- Required: LLM (pick one) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Required: Slack ---
SLACK_BOT_TOKEN=
CSM_SLACK_USER_ID=

# --- Optional: CRM (only if connecting live data) ---
CRM_PROVIDER=manual               # manual | salesforce | hubspot
SALESFORCE_INSTANCE_URL=
SALESFORCE_ACCESS_TOKEN=
HUBSPOT_PRIVATE_APP_TOKEN=

# --- Optional: Call transcripts (only if connecting live data) ---
CALL_TRANSCRIPT_PROVIDER=manual   # manual | gong | fireflies | fathom | zoom
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=
FIREFLIES_API_KEY=
ZOOM_OAUTH_TOKEN=

# --- Optional: Support (only if connecting live data) ---
SUPPORT_PROVIDER=manual           # manual | zendesk | intercom
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
INTERCOM_ACCESS_TOKEN=

# --- Optional: Notion (invisible-handoff only) ---
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=

# --- Optional: model overrides ---
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
