# CRM
CRM_PROVIDER=salesforce  # salesforce | hubspot
SALESFORCE_DOMAIN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
HUBSPOT_API_KEY=

# Call transcripts
CALL_TRANSCRIPT_PROVIDER=gong  # gong | fireflies | zoom
GONG_ACCESS_KEY=
GONG_SECRET_KEY=
FIREFLIES_API_KEY=
ZOOM_JWT_TOKEN=

# Support
SUPPORT_PROVIDER=zendesk  # zendesk | intercom
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
INTERCOM_ACCESS_TOKEN=

# Slack
SLACK_BOT_TOKEN=

# LLM
LLM_PROVIDER=anthropic  # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Trust Radar
TRUST_RADAR_MIN_CONFIDENCE=0.7
LIVE_POLL_INTERVAL_SECONDS=30
MAX_CALL_MONITOR_MINUTES=120
EVENT_LOG_PATH=/tmp/trust_radar_events.jsonl
