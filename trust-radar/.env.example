# Required to run: ANTHROPIC_API_KEY (or OPENAI_API_KEY), SLACK_BOT_TOKEN

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Slack notifications
SLACK_BOT_TOKEN=

# Optional — only needed if connecting live CRM
# CRM_PROVIDER=salesforce
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_ACCESS_TOKEN=
# HUBSPOT_PRIVATE_APP_TOKEN=

# Optional — only needed if connecting live transcripts
# CALL_TRANSCRIPT_PROVIDER=gong
# GONG_ACCESS_KEY=
# GONG_ACCESS_KEY_SECRET=
# FIREFLIES_API_KEY=
# ZOOM_OAUTH_TOKEN=

# Optional — only needed if connecting live support
# SUPPORT_PROVIDER=zendesk
# ZENDESK_SUBDOMAIN=
# ZENDESK_EMAIL=
# ZENDESK_API_TOKEN=
# INTERCOM_ACCESS_TOKEN=

# Trust Radar tuning
TRUST_RADAR_MIN_CONFIDENCE=0.7
LIVE_POLL_INTERVAL_SECONDS=30
MAX_CALL_MONITOR_MINUTES=120
EVENT_LOG_PATH=/tmp/trust_radar_events.jsonl

# Test data (defaults are provided in test.py — override here to customise)
# ACCOUNT_NAME=
# TRANSCRIPT_TEXT=
