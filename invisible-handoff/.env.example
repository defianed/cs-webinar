# Required to run: ANTHROPIC_API_KEY (or OPENAI_API_KEY), SLACK_BOT_TOKEN

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Slack notifications
SLACK_BOT_TOKEN=

# Test data (defaults are provided in test.py — override here to customise)
# ACCOUNT_NAME=
# ACCOUNT_ID=
# OPPORTUNITY_ID=
# TRANSCRIPT_TEXT=
# SALES_SUMMARY=
# CLOSE_NOTES=
# IMPLEMENTATION_CONTEXT=

# Optional — only needed if sending the brief to Notion
# NOTION_API_KEY=
# NOTION_PARENT_PAGE_ID=
