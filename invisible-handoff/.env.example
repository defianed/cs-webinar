# Required to run: ANTHROPIC_API_KEY (or OPENAI_API_KEY), SLACK_BOT_TOKEN

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Slack notifications
SLACK_BOT_TOKEN=

# Optional — only needed if connecting live CRM
# CRM_PROVIDER=salesforce
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_ACCESS_TOKEN=
# HUBSPOT_ACCESS_TOKEN=

# Optional — only needed if connecting live transcripts
# CALL_TRANSCRIPT_PROVIDER=gong
# GONG_ACCESS_KEY=
# GONG_ACCESS_KEY_SECRET=
# FIREFLIES_API_KEY=

# Test data (defaults are provided in test.py — override here to customise)
# ACCOUNT_NAME=
# TRANSCRIPT_TEXT=

# Optional — for writing briefs to Notion
# NOTION_API_KEY=
# NOTION_PARENT_PAGE_ID=
