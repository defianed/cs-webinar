# Required to run: ANTHROPIC_API_KEY (or OPENAI_API_KEY), SLACK_BOT_TOKEN

# LLM Provider (anthropic or openai)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Slack notifications
SLACK_BOT_TOKEN=

# Test data (defaults are provided in test.py — override here to customise)
# ACCOUNT_NAME=
# MILESTONE_ACHIEVED=
# INTERACTION_SUMMARY=
# SENTIMENT_SUMMARY=

# Optional — only needed when connecting live tools
# CRM_PROVIDER=salesforce  # salesforce | hubspot
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_ACCESS_TOKEN=
# HUBSPOT_ACCESS_TOKEN=
